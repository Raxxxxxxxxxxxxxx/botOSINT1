# Environment / secrets
.env

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Runtime data (SQLite db, Telethon session, logs)
data/*.db
data/*.session
data/telethon_session*
logs/*.log
logs/*.log.zip

# Selenium experiment (scripts/selenium_facebook_experiment.py) — local only
data/selenium_chrome_profile/
data/selenium_facebook_experiment_*.json
data/selenium_facebook_last_sent.json

# Keep the directories themselves under version control
!data/.gitkeep
!logs/.gitkeep

# Editors / OS
.vscode/
.idea/
.DS_Store
