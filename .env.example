# Copy this file to `.env` for local development.
# In production (Railway), set these as environment variables instead —
# never commit a real `.env` file.

# --- Required: Telegram ---
BOT_TOKEN=                     # from @BotFather
TARGET_CHAT_ID=                # channel/group/user id to publish news to (e.g. -1001234567890)

# --- Admin panel (optional) ---
# Your numeric Telegram user id (get it from @userinfobot). Leave empty to
# disable the /admin panel entirely — it fails closed, not open.
ADMIN_ID=

# --- Database ---
# Default: local SQLite file. On Railway, this file MUST live on a mounted
# persistent volume, or it is lost on every redeploy.
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# Example for a future PostgreSQL upgrade (requires `pip install asyncpg`):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
# Connection pool sizing. Defaults (20 + 20 = 40 max) are sized for 100+
# sources on short poll intervals; raise if the scheduler logs
# "QueuePool limit ... connection timed out" under a large source count.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
SENTRY_DSN=                     # optional; leave empty to disable Sentry entirely

# --- HTTP fetching ---
HTTP_TIMEOUT_SECONDS=15
HTTP_USER_AGENT=Mozilla/5.0 (compatible; RaqqaNewsBot/1.0; +https://t.me/)

# --- Scheduling / circuit breaker ---
SCHEDULER_DEFAULT_JITTER_SECONDS=20
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_CYCLES=6

# --- Deduplication ---
DEDUP_FUZZY_THRESHOLD=88
DEDUP_WINDOW_HOURS=48
DEDUP_WINDOW_MAX_ITEMS=500

# --- Geographic relevance filter ---
GEO_FUZZY_THRESHOLD=85

# --- Publishing ---
PUBLISH_MIN_INTERVAL_SECONDS=1.2

# --- AI summarization (optional; disabled by default) ---
AI_SUMMARY_ENABLED=false
AI_API_KEY=                    # required only if AI_SUMMARY_ENABLED=true
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# --- Facebook Page posts via Apify (optional; leave APIFY_API_TOKEN empty to disable) ---
# Get a token at https://console.apify.com/settings/integrations
APIFY_API_TOKEN=
APIFY_FACEBOOK_ACTOR_ID=apify~facebook-posts-scraper
APIFY_FACEBOOK_RESULTS_LIMIT=20
APIFY_FACEBOOK_INITIAL_LOOKBACK_DAYS=3
APIFY_RUN_TIMEOUT_SECONDS=320

# --- Selenium Facebook login (scripts/selenium_facebook_experiment.py ONLY) ---
# Not read by the bot itself — only by the standalone local script used to
# perform the one-time interactive login into the Chrome profile below.
# The FACEBOOK_SELENIUM source adapter (config just below) then reuses that
# same logged-in profile automatically; it never reads these credentials.
# Use a throwaway/secondary Facebook account: automated login violates
# Facebook's ToS and the account used can be checkpointed or banned.
FB_SELENIUM_EMAIL=
FB_SELENIUM_PASSWORD=

# --- Facebook Page posts via local Selenium/Chrome (optional; requires Chrome/Chromium
# installed on the server, and only makes sense once self-hosted — Phase 2 excluded
# headless browsers from Railway specifically for resource reasons) ---
# Master switch — leave false everywhere except the self-hosted Docker server.
# When false: the DB migration that reassigns Facebook sources to Selenium is
# skipped and the adapter is never registered, so this code is a no-op on any
# environment (e.g. Railway) that hasn't explicitly set this to true.
SELENIUM_FACEBOOK_ENABLED=false
SELENIUM_FACEBOOK_HEADLESS=true
SELENIUM_FACEBOOK_MAX_POSTS=5
SELENIUM_CHROME_PROFILE_DIR=./data/selenium_chrome_profile
# Leave empty for local dev (Selenium Manager finds an installed Chrome/Chromium
# on its own). The Dockerfile sets this automatically for the container image —
# no need to set it yourself when deploying via Docker.
SELENIUM_CHROME_BINARY=

# --- Telegram-channel monitoring via Telethon (optional; disabled by default) ---
TELETHON_ENABLED=false
TELETHON_API_ID=                # required only if TELETHON_ENABLED=true (from my.telegram.org)
TELETHON_API_HASH=               # required only if TELETHON_ENABLED=true
TELETHON_SESSION_NAME=./data/telethon_session
